# Application
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://appuser:password@db:5432/appdb
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_strong_password

# Redis
REDIS_URL=redis://:changeme_redis_password@redis:6379
REDIS_PASSWORD=changeme_redis_password

# Secrets (generate with: openssl rand -hex 32)
SECRET_KEY=changeme_generate_a_real_secret_key_here
JWT_SECRET=changeme_generate_a_real_jwt_secret_here
