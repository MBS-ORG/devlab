# =============================================================================
# devlab — Global .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & credentials — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
terraform.tfvars
!terraform.tfvars.example

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.workspace
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
dist/
build/
.next/
.nuxt/
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore
docker-compose.override.yml

# -----------------------------------------------------------------------------
# AL / Business Central
# -----------------------------------------------------------------------------
.vscode/
.alcache/
.alpackages/
.snapshots/
.output/
*.app
rad.json
*.g.xlf
*.flf
TestResults.xml

# -----------------------------------------------------------------------------
# Shell / Scripts
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Archives
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.tar.bz2
*.7z
*.rar
